{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "semi": [
      "error",
      "always"
    ],
    "quotes": [
      "warn",
      "single"
    ],
    "indent": [
      "warn",
      2
    ],
    "comma-dangle": [
      "warn",
      "always-multiline"
    ],
    "no-trailing-spaces": "warn",
    "eol-last": [
      "error",
      "always"
    ]
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    ".next/",
    "scratch/"
  ]
}